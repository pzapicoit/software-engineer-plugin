{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "${CURSOR_PLUGIN_ROOT}/hooks/session-context.sh" }
    ],
    "postToolUse": [
      { "command": "${CURSOR_PLUGIN_ROOT}/hooks/task-metrics-tooluse.sh" }
    ],
    "stop": [
      { "command": "${CURSOR_PLUGIN_ROOT}/hooks/task-metrics-stop.sh" }
    ],
    "sessionEnd": [
      { "command": "${CURSOR_PLUGIN_ROOT}/hooks/task-metrics-session-end.sh" }
    ],
    "preCompact": [
      { "command": "${CURSOR_PLUGIN_ROOT}/hooks/task-metrics-compact.sh" }
    ]
  }
}
